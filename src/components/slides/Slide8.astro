---
// Slide8
---
<section class="slide-container slide-full-img">
      <span class="slide-number"></span>
      <img class="pillar-full-img" src="html.png" alt="Только HTML">
    </section>

<style is:global>
/* Slide 8 — House JS */
.house-badge.js-badge {
  background: #fefce8;
  border: 1px solid #fde68a;
  color: #92400e;
}

/* Slide 8 — Prompt template */
.prompt-block {
  background: #1e293b;
  border-radius: 12px;
  padding: 48px 36px 28px 36px;
  font-family: 'Courier New', Courier, monospace;
  font-size: 0.82rem;
  color: #e2e8f0;
  line-height: 1.7;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  position: relative;
  overflow-y: auto;
  text-align: left;
}

.prompt-block::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 40px;
  background: #334155;
  border-radius: 12px 12px 0 0;
}

.prompt-dots {
  position: absolute;
  top: 14px;
  left: 16px;
  display: flex;
  gap: 8px;
  z-index: 1;
}

.prompt-dots span {
  width: 12px;
  height: 12px;
  border-radius: 50%;
}

.prompt-dots span:nth-child(1) {
  background: #ef4444;
}

.prompt-dots span:nth-child(2) {
  background: #f59e0b;
}

.prompt-dots span:nth-child(3) {
  background: #22c55e;
}

.prompt-block .prompt-label {
  position: absolute;
  top: 10px;
  right: 16px;
  font-family: 'Inter', sans-serif;
  font-size: 0.75rem;
  color: #94a3b8;
  z-index: 1;
}

.prompt-block code {
  flex: 1;
  font-size: 0.82rem;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
}

.prompt-block .placeholder {
  color: #60a5fa;
  font-weight: 600;
  background: rgba(37, 99, 235, 0.2);
  padding: 2px 6px;
  border-radius: 4px;
}

.copy-hint {
  margin-top: 12px;
  font-size: 0.9rem;
  color: #64748b;
  display: flex;
  align-items: center;
  gap: 8px;
}

.copy-hint i {
  color: #2563eb;
}
</style>
