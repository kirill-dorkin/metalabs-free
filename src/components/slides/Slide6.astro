---
// Slide6
---
<section class="slide-container slide-full-img"
      style="padding: 40px; display: flex; align-items: center; justify-content: center;">
      <span class="slide-number">05 / 16</span>
      <img class="pillar-full-img" src="t5.png" alt="Три кита веб-разработки"
        style="max-height: 100%; max-width: 100%; object-fit: contain; border-radius: 20px;">
    </section>

<style is:global>
/* Slide 6 — House HTML */
.house-slide {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  flex: 1;
  align-items: stretch;
}

.house-left {
  display: flex;
  flex-direction: column;
  gap: 20px;
  justify-content: center;
}

.house-left .house-text {
  font-size: 1.15rem;
  color: #475569;
  line-height: 1.7;
}

.house-left .house-text strong {
  color: #1e293b;
  font-weight: 600;
}

.house-left .house-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  border-radius: 24px;
  font-size: 0.9rem;
  font-weight: 600;
  width: fit-content;
}

.house-left .house-badge.blue {
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  color: #1e40af;
}

.house-left .house-badge.green {
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  color: #166534;
}

.house-left .house-badge.gold {
  background: #fefce8;
  border: 1px solid #fde68a;
  color: #92400e;
}

.house-left .house-badge i {
  font-size: 16px;
}

.house-right {
  display: flex;
  flex-direction: column;
  gap: 18px;
  justify-content: center;
}

.house-element {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 14px;
  padding: 20px 24px;
  display: flex;
  align-items: flex-start;
  gap: 16px;
  transition: box-shadow 0.2s;
}

.house-element:hover {
  box-shadow: 0 4px 16px rgba(37, 99, 235, 0.08);
}

.house-element .he-icon {
  width: 40px;
  height: 40px;
  min-width: 40px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.house-element .he-icon i {
  font-size: 18px;
}

.house-element .he-icon.orange {
  background: #fff7ed;
}

.house-element .he-icon.orange i {
  color: #ea580c;
}

.house-element .he-icon.blue {
  background: #eff6ff;
}

.house-element .he-icon.blue i {
  color: #2563eb;
}

.house-element .he-icon.green {
  background: #f0fdf4;
}

.house-element .he-icon.green i {
  color: #16a34a;
}

.house-element .he-icon.gold {
  background: #fefce8;
}

.house-element .he-icon.gold i {
  color: #d97706;
}

.house-element .he-icon.purple {
  background: #faf5ff;
}

.house-element .he-icon.purple i {
  color: #9333ea;
}

.house-element .he-content h3 {
  font-size: 1rem;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 4px;
}

.house-element .he-content p {
  font-size: 0.9rem;
  color: #64748b;
  line-height: 1.5;
}

/* Slide 6 — Prompt rules */
.rules-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16px;
  flex: 1;
  align-content: center;
}

.rule-card {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 24px 16px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  transition: transform 0.2s, box-shadow 0.2s;
  cursor: pointer;
}

.rule-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(37, 99, 235, 0.1);
}

.rule-number {
  width: 36px;
  height: 36px;
  background: #2563eb;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 0.9rem;
}

.rule-card i {
  font-size: 24px;
  color: #2563eb;
}

.rule-card h3 {
  font-size: 1rem;
  font-weight: 600;
  color: #1e293b;
}

.rule-card p {
  font-size: 0.82rem;
  color: #64748b;
  line-height: 1.5;
}
</style>
