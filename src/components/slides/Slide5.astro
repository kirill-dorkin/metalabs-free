---
// Slide5
---
<section class="slide-container theory-slide">
      <span class="slide-number"></span>
      <div class="theory-icon">
        <i class="fa-solid fa-book-open"></i>
      </div>
      <h2><i class="fa-solid fa-brain"></i> Немного теории</h2>
      <p class="theory-text">Сейчас мы разберём базовые понятия, на которых строится любой сайт</p>
    </section>

<style is:global>
/* Slide 5 — Three pillars */
.pillars-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 28px;
  flex: 1;
  align-items: stretch;
}

.pillar-card {
  background: #f8fafc;
  border: 2px solid #e2e8f0;
  border-radius: 20px;
  padding: 36px 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 18px;
  transition: box-shadow 0.2s, transform 0.2s;
  cursor: pointer;
}

.pillar-card:hover {
  box-shadow: 0 8px 32px rgba(37, 99, 235, 0.1);
  transform: translateY(-4px);
}

.pillar-card .pillar-icon {
  width: 72px;
  height: 72px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pillar-card .pillar-icon i {
  font-size: 36px;
}

.pillar-card.html .pillar-icon {
  background: #fff7ed;
}

.pillar-card.html .pillar-icon i {
  color: #ea580c;
}

.pillar-card.css .pillar-icon {
  background: #eff6ff;
}

.pillar-card.css .pillar-icon i {
  color: #2563eb;
}

.pillar-card.js .pillar-icon {
  background: #fefce8;
}

.pillar-card.js .pillar-icon i {
  color: #d97706;
}

.pillar-card .pillar-tag {
  font-size: 1.6rem;
  font-weight: 800;
  letter-spacing: 0.05em;
}

.pillar-card.html .pillar-tag {
  color: #ea580c;
}

.pillar-card.css .pillar-tag {
  color: #2563eb;
}

.pillar-card.js .pillar-tag {
  color: #d97706;
}

.pillar-card .pillar-name {
  font-size: 1.1rem;
  font-weight: 600;
  color: #1e293b;
}

.pillar-card .pillar-desc {
  font-size: 0.9rem;
  color: #64748b;
  line-height: 1.6;
}

.pillar-card .pillar-example {
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 12px 16px;
  font-size: 0.8rem;
  color: #475569;
  font-weight: 500;
  width: 100%;
}

.pillar-card .pillar-img {
  width: 100%;
  height: 120px;
  border-radius: 12px;
  object-fit: cover;
  border: 1px solid #e2e8f0;
  margin-top: auto;
}

.pillars-intro {
  text-align: center;
  margin-bottom: 12px;
}

.pillars-intro p {
  font-size: 1.1rem;
  color: #475569;
  line-height: 1.6;
  max-width: 700px;
  margin: 0 auto;
}

.pillars-intro strong {
  color: #1e293b;
}

.pillar-full-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  margin: 0;
  padding: 0;
  border-radius: 12px;
  border: 2px solid #e2e8f0;
}

.slide-full-img {
  padding: 0 !important;
}

/* Slide 5 — Intro */
.ai-content {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 40px;
  flex: 1;
  align-items: center;
}

.ai-text p {
  font-size: 1.05rem;
  color: #475569;
  margin-bottom: 16px;
}

.ai-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 24px;
}

.stat-card {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 20px;
  text-align: center;
}

.stat-card .stat-value {
  font-size: 1.75rem;
  font-weight: 700;
  color: #2563eb;
}

.stat-card .stat-label {
  font-size: 0.85rem;
  color: #64748b;
  margin-top: 4px;
}

.ai-image {
  width: 100%;
  height: 320px;
  border-radius: 12px;
  object-fit: cover;
  border: 1px solid #e2e8f0;
}

/* Slide 5 — Theory */
.theory-slide {
  justify-content: center;
  align-items: center;
  text-align: center;
  background: #ffffff;
}

.theory-slide h2 {
  justify-content: center;
  font-size: 2.5rem;
}

.theory-slide .theory-text {
  font-size: 1.3rem;
  color: #475569;
  max-width: 600px;
  margin-bottom: 40px;
}

.theory-icon {
  width: 96px;
  height: 96px;
  background: linear-gradient(135deg, #4f46e5 0%, #ec4899 100%);
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32px;
  animation: float 3s ease-in-out infinite;
  box-shadow: 0 10px 32px rgba(79, 70, 229, 0.25);
}

.theory-icon i {
  font-size: 42px;
  color: #ffffff;
}

@keyframes pulse {

  0%,
  100% {
    transform: scale(1);
  }

  50% {
    transform: scale(1.05);
  }
}
</style>
